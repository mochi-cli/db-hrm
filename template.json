{
  "name": "hrm",
  "displayName": "HRM",
  "description": "HRM workspace with Departments, Jobs, Employees, Attendance, and Payroll.",
  "version": "0.2.1",
  "mochi-cli": ">=0.1.0",
  "collections": [
    {
      "name": "Departments",
      "schema": {
        "titleField": "department_name",
        "fields": {
          "department_id": {
            "type": "primary_key"
          },
          "department_name": {
            "type": "varchar(100)",
            "unique": true,
            "required": true
          },
          "manager_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Employees",
              "field": "employee_id"
            },
            "nullable": true
          },
          "location": {
            "type": "varchar(150)",
            "nullable": true
          }
        }
      }
    },
    {
      "name": "Jobs",
      "schema": {
        "titleField": "job_title",
        "fields": {
          "job_id": {
            "type": "primary_key"
          },
          "job_title": {
            "type": "varchar(100)",
            "unique": true,
            "required": true
          },
          "min_salary": {
            "type": "decimal(10,2)",
            "required": true
          },
          "max_salary": {
            "type": "decimal(10,2)",
            "required": true
          }
        }
      }
    },
    {
      "name": "Employees",
      "schema": {
        "titleField": "email",
        "fields": {
          "employee_id": {
            "type": "primary_key"
          },
          "first_name": {
            "type": "varchar(50)",
            "required": true
          },
          "last_name": {
            "type": "varchar(50)",
            "required": true
          },
          "email": {
            "type": "varchar(100)",
            "unique": true,
            "required": true
          },
          "phone_number": {
            "type": "varchar(20)",
            "nullable": true
          },
          "hire_date": {
            "type": "date",
            "required": true
          },
          "job_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Jobs",
              "field": "job_id"
            },
            "required": true
          },
          "department_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Departments",
              "field": "department_id"
            },
            "nullable": true
          },
          "manager_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Employees",
              "field": "employee_id"
            },
            "nullable": true
          },
          "salary": {
            "type": "decimal(10,2)",
            "required": true
          },
          "status": {
            "type": "varchar(20)",
            "default": "Active"
          }
        }
      }
    },
    {
      "name": "Attendance",
      "schema": {
        "titleField": "work_date",
        "fields": {
          "attendance_id": {
            "type": "primary_key"
          },
          "employee_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Employees",
              "field": "employee_id"
            },
            "required": true
          },
          "work_date": {
            "type": "date",
            "required": true
          },
          "clock_in": {
            "type": "timestamp",
            "nullable": true
          },
          "clock_out": {
            "type": "timestamp",
            "nullable": true
          },
          "status": {
            "type": "varchar(20)",
            "default": "Present"
          }
        },
        "constraints": [
          {
            "type": "unique",
            "fields": [
              "employee_id",
              "work_date"
            ]
          }
        ]
      }
    },
    {
      "name": "Payroll",
      "schema": {
        "titleField": "payment_date",
        "fields": {
          "payroll_id": {
            "type": "primary_key"
          },
          "employee_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Employees",
              "field": "employee_id"
            },
            "required": true
          },
          "payment_date": {
            "type": "date",
            "required": true
          },
          "gross_salary": {
            "type": "decimal(10,2)",
            "required": true
          },
          "deductions": {
            "type": "decimal(10,2)",
            "default": "0.00"
          },
          "net_salary": {
            "type": "number",
            "generated": {
              "expression": "gross_salary - deductions"
            },
            "readOnly": true
          },
          "payment_method": {
            "type": "varchar(30)",
            "default": "Bank Transfer"
          }
        }
      }
    }
  ],
  "relationships": [
    "Departments.manager_id -> Employees.employee_id",
    "Employees.job_id -> Jobs.job_id",
    "Employees.department_id -> Departments.department_id",
    "Employees.manager_id -> Employees.employee_id",
    "Attendance.employee_id -> Employees.employee_id",
    "Payroll.employee_id -> Employees.employee_id"
  ]
}
