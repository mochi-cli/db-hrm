{
  "name": "Attendance",
  "titleField": "work_date",
  "fields": {
    "attendance_id": {
      "type": "primary_key"
    },
    "employee_id": {
      "type": "foreign_key",
      "relation": {
        "collection": "Employees",
        "field": "employee_id"
      },
      "required": true
    },
    "work_date": {
      "type": "date",
      "required": true
    },
    "clock_in": {
      "type": "timestamp",
      "nullable": true
    },
    "clock_out": {
      "type": "timestamp",
      "nullable": true
    },
    "status": {
      "type": "varchar(20)",
      "default": "Present"
    }
  },
  "constraints": [
    {
      "type": "unique",
      "fields": [
        "employee_id",
        "work_date"
      ]
    }
  ]
}
