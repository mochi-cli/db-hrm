{
  "name": "Employees",
  "titleField": "email",
  "fields": {
    "employee_id": "primary_key",
    "first_name": "varchar(50), required",
    "last_name": "varchar(50), required",
    "email": "varchar(100), unique, required",
    "phone_number": "varchar(20), nullable",
    "hire_date": "date, required",
    "job_id": "foreign_key:Jobs(job_id), required",
    "department_id": "foreign_key:Departments(department_id), nullable",
    "manager_id": "foreign_key:Employees(employee_id), nullable",
    "salary": "decimal(10,2), required",
    "status": "varchar(20), default:Active"
  }
}
