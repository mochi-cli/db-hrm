{
  "name": "Employees",
  "titleField": "email",
  "fields": {
    "employee_id": {
      "type": "primary_key"
    },
    "first_name": {
      "type": "varchar(50)",
      "required": true
    },
    "last_name": {
      "type": "varchar(50)",
      "required": true
    },
    "email": {
      "type": "varchar(100)",
      "unique": true,
      "required": true
    },
    "phone_number": {
      "type": "varchar(20)",
      "nullable": true
    },
    "hire_date": {
      "type": "date",
      "required": true
    },
    "job_id": {
      "type": "foreign_key",
      "relation": {
        "collection": "Jobs",
        "field": "job_id"
      },
      "required": true
    },
    "department_id": {
      "type": "foreign_key",
      "relation": {
        "collection": "Departments",
        "field": "department_id"
      },
      "nullable": true
    },
    "manager_id": {
      "type": "foreign_key",
      "relation": {
        "collection": "Employees",
        "field": "employee_id"
      },
      "nullable": true
    },
    "salary": {
      "type": "decimal(10,2)",
      "required": true
    },
    "status": {
      "type": "varchar(20)",
      "default": "Active"
    }
  }
}
